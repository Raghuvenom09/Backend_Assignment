<%- include('../partials/header') %>

    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1 class="text-center mb-4">Add a New Book</h1>
            <form action="/book" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label class="form-label" for="title">Title <span class="text-danger">*</span></label>
                    <input class="form-control" type="text" id="title" name="book[title]" required>
                    <div class="invalid-feedback">Title is required.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="author">Author <span class="text-danger">*</span></label>
                    <input class="form-control" type="text" id="author" name="book[author]" required>
                    <div class="invalid-feedback">Author is required.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="genre">Genre <span class="text-danger">*</span></label>
                    <input class="form-control" type="text" id="genre" name="book[genre]" required>
                    <div class="invalid-feedback">Genre is required.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="publishedDate">Published Date <span
                            class="text-danger">*</span></label>
                    <input class="form-control" type="date" id="publishedDate" name="book[publishedDate]" required>
                    <div class="invalid-feedback">Please provide a valid date.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="rating">Rating <span class="text-danger">*</span></label>
                    <input class="form-control" type="number" id="rating" name="book[rating]" min="1" max="5" required>
                    <div class="invalid-feedback">Rating must be between 1 and 5.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="review">Review</label>
                    <textarea class="form-control" type="text" id="review" name="book[review]" rows="3"></textarea>
                </div>

                <button class="btn btn-success w-100">Add Book</button>
            </form>
            <div class="mt-3 text-center">
                <a href="/books">Back to All Books</a>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>