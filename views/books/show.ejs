<%- include('../partials/header') %>

    <div class="row mt-4">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-body">
                    <h2 class="card-title text-primary">
                        <%= book.title %>
                    </h2>
                    <h5 class="card-subtitle mb-4 text-muted">Author: <%= book.author %>
                    </h5>

                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item"><strong>Genre:</strong>
                            <%= book.genre %>
                        </li>
                        <li class="list-group-item"><strong>Published Date:</strong>
                            <%= new Date(book.publishedDate).toLocaleDateString() %>
                        </li>
                        <li class="list-group-item"><strong>Rating:</strong>
                            <%= book.rating %> / 5
                        </li>
                    </ul>

                    <% if(book.review) { %>
                        <div class="card mb-4 border-info">
                            <div class="card-header bg-info text-dark">
                                <strong>Review</strong>
                            </div>
                            <div class="card-body">
                                <p class="card-text">
                                    <%= book.review %>
                                </p>
                            </div>
                        </div>
                        <% } %>

                            <div class="d-flex justify-content-between">
                                <div>
                                    <a href="/books/<%= book._id %>/edit" class="btn btn-warning">Edit</a>
                                    <form class="d-inline" action="/books/<%= book._id %>?_method=DELETE" method="POST">
                                        <button class="btn btn-danger"
                                            onclick="return confirm('Are you sure you want to delete this book?');">Delete</button>
                                    </form>
                                </div>
                                <a href="/books" class="btn btn-secondary">Back to Books</a>
                            </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>