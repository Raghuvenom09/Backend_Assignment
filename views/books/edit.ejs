<%- include('../partials/header') %>

    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1 class="text-center mb-4">Edit Book</h1>
            <form action="/books/<%= book._id %>?_method=PUT" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label class="form-label" for="title">Title (Read Only) <span class="text-danger">*</span></label>
                    <!-- Added readonly attribute to prevent editing as required -->
                    <input class="form-control bg-light" type="text" id="title" name="book[title]"
                        value="<%= book.title %>" readonly required>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="author">Author <span class="text-danger">*</span></label>
                    <input class="form-control" type="text" id="author" name="book[author]" value="<%= book.author %>"
                        required>
                    <div class="invalid-feedback">Author is required.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="genre">Genre <span class="text-danger">*</span></label>
                    <input class="form-control" type="text" id="genre" name="book[genre]" value="<%= book.genre %>"
                        required>
                    <div class="invalid-feedback">Genre is required.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="publishedDate">Published Date <span
                            class="text-danger">*</span></label>
                    <!-- Convert date to YYYY-MM-DD for the value attribute -->
                    <input class="form-control" type="date" id="publishedDate" name="book[publishedDate]"
                        value="<%= book.publishedDate.toISOString().substring(0, 10) %>" required>
                    <div class="invalid-feedback">Please provide a valid date.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="rating">Rating <span class="text-danger">*</span></label>
                    <input class="form-control" type="number" id="rating" name="book[rating]" value="<%= book.rating %>"
                        min="1" max="5" required>
                    <div class="invalid-feedback">Rating must be between 1 and 5.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="review">Review</label>
                    <textarea class="form-control" type="text" id="review" name="book[review]"
                        rows="3"><%= book.review %></textarea>
                </div>

                <button class="btn btn-info w-100">Update Book</button>
            </form>
            <div class="mt-3 text-center">
                <a href="/books/<%= book._id %>">Cancel Edit</a>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>