<%- include('../partials/header') %>

    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1 class="text-center">Register</h1>
            <form action="/register" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label class="form-label" for="username">Username</label>
                    <input class="form-control" type="text" id="username" name="username" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a username.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="password">Password</label>
                    <input class="form-control" type="password" id="password" name="password" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a password.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="favoriteAuthor">Favorite Author</label>
                    <input class="form-control" type="text" id="favoriteAuthor" name="favoriteAuthor" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter your favorite author.</div>
                </div>

                <button class="btn btn-success w-100">Register</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>